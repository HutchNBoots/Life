# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo layout (v1/, v2/) — patterns below are unrooted so they match
# at any depth, not just the repo root.

# dependencies
node_modules
.pnp
.pnp.js
.yarn/install-state.gz

# testing
coverage

# next.js
.next/
out/

# production
build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
